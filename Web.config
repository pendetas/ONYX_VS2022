<?xml version="1.0" encoding="utf-8"?>
<!--
  For more information on how to configure your ASP.NET application, please visit
  https://go.microsoft.com/fwlink/?LinkId=169433
  -->
<configuration>
  <connectionStrings>
    <!-- Pointing both to your local DB for development -->
    <add name="DefaultConnection" connectionString="Host=localhost;Port=5432;Database=onyx;Username=postgres;Password=1212;Pooling=true;Minimum Pool Size=1;Maximum Pool Size=100;Keepalive=30;" providerName="Npgsql" />
    <add name="ReadConnection" connectionString="Host=localhost;Port=5432;Database=onyx;Username=postgres;Password=1212;Pooling=true;Minimum Pool Size=1;Maximum Pool Size=100;Keepalive=30;" providerName="Npgsql" />
  </connectionStrings>
  <appSettings file="AppSettings.Local.config">
    <add key="AWSRegion" value="ap-southeast-1" />
    <add key="S3BucketName" value="onyx-assets" />
    <add key="ApiGatewayBaseUrl" value="https://example.execute-api.ap-southeast-1.amazonaws.com" />
    <add key="AdminEmail" value="admin@onyx.com" />
    <add key="GeminiModel" value="gemini-3.5-flash" />
    <!-- Local development placeholders. Replace locally; never commit live credentials. -->
    <add key="AppBaseUrl" value="https://REPLACE_APP_BASE_URL" />
    <add key="StripeAppBaseUrl" value="https://REPLACE_APP_BASE_URL" />
    <add key="ONYX_MEDIA_API_URL" value="https://REPLACE_API_ID.execute-api.ap-southeast-1.amazonaws.com/media/upload-url" />
    <add key="ONYX_MEDIA_API_TOKEN" value="REPLACE_ONYX_MEDIA_API_TOKEN" />
    <add key="ONYX_MEDIA_DELIVERY_BASE_URL" value="https://REPLACE_CLOUDFRONT_DOMAIN.cloudfront.net" />
    <add key="GeminiApiKey" value="REPLACE_GEMINI_API_KEY" />
    <add key="TurnstileSiteKey" value="REPLACE_TURNSTILE_SITE_KEY" />
    <add key="TurnstileSecretKey" value="REPLACE_TURNSTILE_SECRET_KEY" />
    <add key="GoogleClientId" value="REPLACE_GOOGLE_CLIENT_ID" />
    <add key="GoogleClientSecret" value="REPLACE_GOOGLE_CLIENT_SECRET" />
    <add key="DiscordClientId" value="REPLACE_DISCORD_CLIENT_ID" />
    <add key="DiscordClientSecret" value="REPLACE_DISCORD_CLIENT_SECRET" />
    <add key="FacebookClientId" value="REPLACE_FACEBOOK_CLIENT_ID" />
    <add key="FacebookClientSecret" value="REPLACE_FACEBOOK_CLIENT_SECRET" />
    <add key="XClientId" value="REPLACE_X_CLIENT_ID" />
    <add key="XClientSecret" value="REPLACE_X_CLIENT_SECRET" />
    <add key="SmtpHost" value="smtp.gmail.com" />
    <add key="SmtpPort" value="587" />
    <add key="SmtpEnableSsl" value="true" />
    <add key="SmtpUsername" value="REPLACE_SMTP_USERNAME" />
    <add key="SmtpPassword" value="REPLACE_SMTP_APP_PASSWORD" />
    <add key="EmailFromAddress" value="REPLACE_SUPPORT_EMAIL" />
    <add key="EmailFromName" value="ONYX Support" />
  </appSettings>
  <system.web>
    <compilation debug="true" targetFramework="4.8" />
    <httpRuntime targetFramework="4.8" maxRequestLength="51200" executionTimeout="300" />
    <authentication mode="Forms">
      <forms loginUrl="~/auth_page/onyx_login.aspx" timeout="10080" />
    </authentication>
    <sessionState mode="InProc" timeout="60" />
    <pages>
      <namespaces>
        <add namespace="System.Web.Optimization" />
      </namespaces>
      <controls>
        <add assembly="Microsoft.AspNet.Web.Optimization.WebForms" namespace="Microsoft.AspNet.Web.Optimization.WebForms" tagPrefix="webopt" />
      </controls>
    </pages>
  </system.web>
  <system.webServer>
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="52428800" />
      </requestFiltering>
    </security>
  </system.webServer>
