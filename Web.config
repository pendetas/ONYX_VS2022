<?xml version="1.0" encoding="utf-8"?>
<!--
  For more information on how to configure your ASP.NET application, please visit
  https://go.microsoft.com/fwlink/?LinkId=169433
  -->
<configuration>
	<connectionStrings>
		<add name="DefaultConnection" connectionString="Host=localhost;Port=5432;Database=onyx;Username=postgres;Password=REPLACE_DATABASE_PASSWORD;Pooling=true;Minimum Pool Size=1;Maximum Pool Size=100;Keepalive=30;" providerName="Npgsql" />
		<add name="ReadConnection" connectionString="Host=localhost;Port=5432;Database=onyx;Username=postgres;Password=REPLACE_DATABASE_PASSWORD;Pooling=true;Minimum Pool Size=1;Maximum Pool Size=100;Keepalive=30;" providerName="Npgsql" />
	</connectionStrings>
  <appSettings>
    <add key="AWSRegion" value="ap-southeast-1" />
    <add key="S3BucketName" value="onyx-assets" />
    <add key="ApiGatewayBaseUrl" value="https://example.execute-api.ap-southeast-1.amazonaws.com" />
    <add key="AdminEmail" value="admin@onyx.com" />
    <!-- Local development only. Release transforms replace these test values. -->
    <add key="TurnstileSiteKey" value="1x00000000000000000000AA" />
    <add key="TurnstileSecretKey" value="1x0000000000000000000000000000000AA" />
    <add key="OtpHmacSecret" value="onyx-local-dev-otp-secret-change-before-production-123456" />
    <add key="OtpExpiryMinutes" value="10" />
    <add key="OtpMaxAttempts" value="5" />
    <add key="OtpResendCooldownSeconds" value="60" />
    <add key="OtpMaxResends" value="3" />
    <add key="SmtpHost" value="localhost" />
    <add key="SmtpPort" value="2525" />
    <add key="SmtpEnableSsl" value="false" />
    <add key="SmtpUsername" value="" />
    <add key="SmtpPassword" value="" />
    <add key="EmailFromAddress" value="no-reply@onyx.local" />
    <add key="EmailFromName" value="ONYX" />
  </appSettings>
  <system.web>
    <compilation debug="true" targetFramework="4.8" />
    <httpRuntime targetFramework="4.8" requestValidationMode="4.5" enableVersionHeader="false" />
    <authentication mode="Forms">
      <forms loginUrl="~/auth_page/onyx_login.aspx"
             timeout="60"
             slidingExpiration="true"
             protection="All"
             cookieless="UseCookies"
             requireSSL="false"
             cookieSameSite="Lax" />
    </authentication>
    <httpCookies httpOnlyCookies="true" requireSSL="false" sameSite="Lax" />
    <sessionState mode="InProc"
                  timeout="30"
                  cookieless="UseCookies"
                  regenerateExpiredSessionId="true"
                  cookieSameSite="Lax" />
    <customErrors mode="RemoteOnly" />
    <pages enableViewStateMac="true"
           enableEventValidation="true"
           viewStateEncryptionMode="Auto"
           validateRequest="true">
      <namespaces>
        <add namespace="System.Web.Optimization" />
      </namespaces>
      <controls>
        <add assembly="Microsoft.AspNet.Web.Optimization.WebForms" namespace="Microsoft.AspNet.Web.Optimization.WebForms" tagPrefix="webopt" />
      </controls>
    </pages>
  </system.web>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="Antlr3.Runtime" publicKeyToken="eb42632606e9261f" />
